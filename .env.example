# URL API Supabase Anda (bisa didapatkan di Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co

# API Key Supabase Anda (gunakan Service Role Key untuk backend agar bypass RLS)
SUPABASE_KEY=your-supabase-service-role-key

# Nama Bucket Supabase Storage yang digunakan (opsional, default: books)
SUPABASE_BUCKET=books

# Port yang digunakan backend (opsional, default: 8080)
PORT=8080
